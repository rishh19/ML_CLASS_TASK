   "source": [
    "import numpy as np\n",
    "\n",
    "# Input dataset (AND logic example)\n",
    "X = np.array([\n",
    "    [0,0],\n",
    "    [0,1],\n",
    "    [1,0],\n",
    "    [1,1]\n",
    "])\n",
    "\n",
    "# Weights\n",
    "weights = np.array([1,1])\n",
    "\n",
    "# Threshold\n",
    "threshold = 2\n",
    "\n",
    "# McCulloch-Pitts Neuron\n",
    "def mcp_neuron(x):\n",
    "    summation = np.dot(x, weights)\n",
    "    if summation >= threshold:\n",
    "        return 1\n",
    "    else:\n",
    "        return 0\n",
    "\n",
    "# Predictions\n",
    "print(\"Outputs:\")\n",
    "for x in X:\n",
    "    print(x, \"->\", mcp_neuron(x))"
   ]
  }
